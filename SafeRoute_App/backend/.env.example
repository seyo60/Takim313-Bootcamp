# SafeRoute Backend — ornek ortam degiskenleri.
# ---------------------------------------------------------------------------
# Bu dosya SADECE sablondur. Gercek degerleri buraya YAZMAYIN; kopyalayin:
#     cp .env.example .env
# .env dosyasi .gitignore'dadir. Prod'da bu degerler platformun (Render) ortam
# degiskenleri / GitHub Secrets uzerinden verilir — koda GOMULMEZ.
# ---------------------------------------------------------------------------

# --- Veritabani (PostgreSQL + PostGIS) ---
# Lokal Docker Compose icin:
DATABASE_URL=postgresql+asyncpg://saferoute:saferoute@localhost:5432/saferoute
# Supabase icin (Deploy - P3): connection string'i asyncpg semasina cevirin.
# Supabase'de ayri SUPABASE_URL / SUPABASE_SERVICE_KEY DEGIL, tek DATABASE_URL kullanilir:
# DATABASE_URL=postgresql+asyncpg://postgres:<SIFRE>@db.<PROJE>.supabase.co:5432/postgres

# entrypoint.sh pg_isready icin (Docker Compose'da "db"; Supabase'de host adi):
# DB_HOST=db.<PROJE>.supabase.co
# DB_USER=postgres

# --- Graf dosyasi ---
GRAPH_PATH=../data-science/chicago.graphml

# --- LLM Ayarlari ---
# mock = API anahtari gerekmez (kural tabanli), live = gercek LLM API
LLM_MODE=mock
# gemini | deepseek | openai  (birincil: gemini)
LLM_PROVIDER=gemini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

ALERT_RADIUS_METERS=500

# --- İlk deploy'da bir kereligine (Chicago suc verisini yukler) ---
# SEED_ON_START=true

# ===========================================================================
# CI/CD — GitHub repo Settings > Secrets olarak eklenmesi gerekenler:
#   RENDER_DEPLOY_HOOK_URL  -> Render "Deploy Hook" URL'i (main deploy'u tetikler)
#   (DATABASE_URL, GEMINI_API_KEY vb. gercek prod degerleri Render ortam
#    degiskenlerinde tutulur; testler DB'yi stub'ladigi icin CI'da secret gerekmez.)
#
# Not: MAPBOX_TOKEN backend'e ait DEGILDIR — mobil tarafta kullanilir
# (mobile-app/.env.example -> EXPO_PUBLIC_MAPBOX_TOKEN).
# ===========================================================================
