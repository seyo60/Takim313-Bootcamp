# Copy this file to `.env` and fill in real values. `.env` is gitignored —
# never commit your actual tokens.

# Mapbox PUBLIC token (starts with pk.). Used at runtime by the JS bundle to
# render the map. Create one at https://account.mapbox.com/access-tokens/
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here

# Mapbox SECRET download token (starts with sk.) with the DOWNLOADS:READ scope.
# Used at native BUILD time so Gradle/CocoaPods can fetch the Mapbox SDK.
# app.config.js maps this onto RNMAPBOX_MAPS_DOWNLOAD_TOKEN.
MAPBOX_DOWNLOAD_TOKEN=sk.your_secret_download_token_here

# Backend base URL — the FastAPI server (e.g. a teammate's ngrok tunnel).
# No trailing slash. Read by src/lib/api.ts.
EXPO_PUBLIC_API_BASE_URL=https://your-backend.ngrok-free.dev
