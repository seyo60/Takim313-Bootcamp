# LLM modu: mock (API key gerekmez) veya live (gerçek API)
LLM_MODE=live

# Sağlayıcı: deepseek | openai | gemini
LLM_PROVIDER=deepseek

# DeepSeek (varsayılan)
DEEPSEEK_API_KEY=buraya-api-key-yaz
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI (alternatif)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini (alternatif)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# LLM parametreleri
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# Yakın kullanıcı arama yarıçapı (metre)
ALERT_RADIUS_METERS=500
